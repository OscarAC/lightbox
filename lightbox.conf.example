# lightbox configuration
#
# Place this file at ~/.config/lightbox/lightbox.conf
# All values are optional — built-in defaults are shown below.

# Base directory for lightbox metadata (container configs, IP files)
# lightbox_dir = /etc/lightbox

# Default rootfs to copy when creating containers
# Can also be set via LIGHTBOX_ROOTFS env var or --rootfs flag
# Derived from lightbox_dir if not set explicitly
# rootfs = /etc/lightbox/rootfs

# Where containers are stored (each gets a subdirectory with rootfs/ and metadata)
# Derived from lightbox_dir if not set explicitly
# container_dir = /etc/lightbox/containers

# PID file directory
# run_dir = /run

# cgroup v2 mount point
# cgroup_root = /sys/fs/cgroup

# Bridge interface and network
# bridge = br0
# subnet = 10.0.0.0/24
# gw = 10.0.0.1

# Default container resource limits
# default_mem = 256M
# default_pids = 128
# default_cpu = 1
# default_oom = 500
